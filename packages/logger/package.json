{
  "name": "@damn-auth/logger",
  "version": "0.1.0",
  "description": "Structured logging for Damn Auth.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "clean": "rimraf dist",
    "lint": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "rimraf": "^6.0.1"
  },
  "peerDependencies": {
    "pino": "^9.5.0"
  },
  "peerDependenciesMeta": {
    "pino": {
      "optional": true
    }
  }
}
