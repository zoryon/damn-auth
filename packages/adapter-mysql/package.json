{
  "name": "@damn-auth/adapter-mysql",
  "version": "0.1.0",
  "description": "MySQL adapter for Damn Auth.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "clean": "rimraf dist",
    "lint": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@damn-auth/core": "workspace:*",
    "mysql2": "^3.11.5"
  },
  "devDependencies": {
    "rimraf": "^6.0.1"
  }
}
